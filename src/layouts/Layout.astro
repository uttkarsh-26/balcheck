---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'बैंक बैलेंस मिस्ड कॉल नंबर — सभी बैंकों के balance enquiry missed call numbers एक जगह' } = Astro.props;
const siteUrl = 'https://balcheck.in';
---

<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- System fonts only — Noto Sans Devanagari is the default Android Devanagari face;
       Inter is replaced by system-ui (Android Roboto/Fira). Eliminates the
       render-blocking external fonts.googleapis.com chain (PageSpeed 79 -> target 90+). -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, siteUrl).href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="hi_IN" />
  
  <!-- Canonical -->
  <link rel="canonical" href={new URL(Astro.url.pathname, siteUrl).href} />
  
  <!-- Theme color -->
  <meta name="theme-color" content="#2563eb" />

  <!-- Google Analytics (GA4) — deferred to next paint, not blocking -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-ZEL0FEF89W');
  </script>
  <script src="https://www.googletagmanager.com/gtag/js?id=G-ZEL0FEF89W" defer></script>
</head>
<body class="bg-gray-50 font-hindi antialiased">
  <!-- Monetag Multitag (all-in-one monetization) -->
  <script src="https://quge5.com/88/tag.min.js" data-zone="251914" async data-cfasync="false"></script>

  <!-- Monetag ad position fix: push top fixed iframes below sticky header, hide duplicate top ads only -->
  <script is:inline>
    (function() {
      const HEADER_HEIGHT = 70;
      const TOP_AD_THRESHOLD = 100;
      const manageAds = function() {
        const fixedIframes = document.querySelectorAll('iframe[style*="position: fixed"], iframe[style*="position:fixed"]');
        let topAdIndex = 0;
        fixedIframes.forEach(function(iframe) {
          const rect = iframe.getBoundingClientRect();
          const currentTop = parseInt(iframe.style.top, 10) || rect.top || 0;
          // Only touch top-positioned ads; leave bottom in-page push ads alone
          if (currentTop < TOP_AD_THRESHOLD) {
            if (topAdIndex === 0) {
              iframe.style.top = HEADER_HEIGHT + 'px';
            } else {
              iframe.style.display = 'none'; // duplicate top ad
            }
            topAdIndex++;
          }
        });
      };
      manageAds();
      const interval = setInterval(manageAds, 200);
      setTimeout(function() { clearInterval(interval); }, 5000);
      const observer = new MutationObserver(manageAds);
      observer.observe(document.body, { childList: true, subtree: true });
    })();
  </script>

  <slot />
</body>
</html>
