---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'बैंक बैलेंस मिस्ड कॉल नंबर — सभी बैंकों के balance enquiry missed call numbers एक जगह' } = Astro.props;
const siteUrl = 'https://balcheck.in';

// HTML: browser always revalidates (max-age=0), CF edge caches 1h with SWR
// Short edge TTL ensures deploys are visible within ~1h even if purge fails
Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, max-age=0, stale-while-revalidate=86400');
---

<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- System fonts only — Noto Sans Devanagari is the default Android Devanagari face;
       Inter is replaced by system-ui (Android Roboto/Fira). Eliminates the
       render-blocking external fonts.googleapis.com chain (PageSpeed 79 -> target 90+). -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, siteUrl).href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="hi_IN" />
  
  <!-- Canonical -->
  <link rel="canonical" href={new URL(Astro.url.pathname, siteUrl).href} />
  
  <!-- Theme color -->
  <meta name="theme-color" content="#2563eb" />

  <!-- Google Analytics (GA4) — production hostname only.
       Dynamic loading prevents localhost/Playwright traffic from polluting GA4. -->
  <script>
    if (window.location.hostname === 'balcheck.in' || window.location.hostname === 'www.balcheck.in') {
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ZEL0FEF89W');

      const analyticsScript = document.createElement('script');
      analyticsScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-ZEL0FEF89W';
      analyticsScript.async = true;
      document.head.appendChild(analyticsScript);
    }
  </script>
</head>
<body class="bg-gray-50 font-hindi antialiased">
  <!-- Monetag Multitag (all-in-one monetization) -->
  <script src="https://quge5.com/88/tag.min.js" data-zone="251914" async data-cfasync="false"></script>

  <slot />
</body>
</html>
