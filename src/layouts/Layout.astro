---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'बैंक बैलेंस मिस्ड कॉल नंबर — सभी बैंकों के balance enquiry missed call numbers एक जगह' } = Astro.props;
const siteUrl = 'https://balcheck.in';
---

<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- System fonts only — Noto Sans Devanagari is the default Android Devanagari face;
       Inter is replaced by system-ui (Android Roboto/Fira). Eliminates the
       render-blocking external fonts.googleapis.com chain (PageSpeed 79 -> target 90+). -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={new URL(Astro.url.pathname, siteUrl).href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="hi_IN" />
  
  <!-- Canonical -->
  <link rel="canonical" href={new URL(Astro.url.pathname, siteUrl).href} />
  
  <!-- Theme color -->
  <meta name="theme-color" content="#2563eb" />

  <!-- Google Analytics (GA4) — deferred to next paint, not blocking -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-ZEL0FEF89W');
  </script>
  <script src="https://www.googletagmanager.com/gtag/js?id=G-ZEL0FEF89W" defer></script>
</head>
<body class="bg-gray-50 font-hindi antialiased">
  <!-- Monetag Ads -->
  <script>(function(s){s.dataset.zone='10542784',s.src='https://gizokraijaw.net/vignette.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>
  <script>(function(s){s.dataset.zone='10542790',s.src='https://nap5k.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>

  <slot />
</body>
</html>
