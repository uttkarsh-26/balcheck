---
import Layout from '../../layouts/Layout.astro';
import { banks } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map((bank: Bank) => ({
    params: { slug: bank.slug },
    props: { bank },
  }));
}

interface Props {
  bank: Bank;
}

const { bank } = Astro.props;
const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/balance-enquiry/${bank.slug}/`;

const title = `${bank.shortName} Balance Enquiry Number — ${bank.nameHindi} बैलेंस चेक | BalCheck`;
const description = `${bank.name} (${bank.shortName}) balance enquiry number ${bank.missedCall}। रजिस्टर्ड मोबाइल से मिस्ड कॉल दें और SMS में बैलेंस पाएं। मुफ़्त, 24×7।`;

const faqs = [
  {
    q: `${bank.shortName} balance enquiry number क्या है?`,
    a: `${bank.name} का balance enquiry number ${bank.missedCall} है। इस पर अपने registered mobile से missed call दें और SMS में बैलेंस पाएं। यह सेवा मुफ़्त है और 24×7 उपलब्ध है।`,
  },
  {
    q: `${bank.nameHindi} से बैलेंस कैसे चेक करें?`,
    a: `${bank.nameHindi} खाते का बैलेंस जानने के लिए ${bank.missedCall} पर अपने रजिस्टर्ड मोबाइल नंबर से मिस्ड कॉल दें। 2-3 ring के बाद कॉल कट जाएगी और कुछ सेकंड में SMS में आपका बैलेंस आ जाएगा।`,
  },
  {
    q: `क्या ${bank.shortName} balance enquiry मुफ़्त है?`,
    a: `हाँ, ${bank.name} की missed call balance enquiry सेवा बिल्कुल मुफ़्त है। आपको कोई charge नहीं देना। बस आपका मोबाइल नंबर बैंक में रजिस्टर्ड होना चाहिए।`,
  },
  {
    q: `${bank.shortName} balance SMS नहीं आया तो क्या करें?`,
    a: `अगर balance SMS नहीं आता तो: 1) जांचें कि आपका नंबर ${bank.name} में रजिस्टर्ड है, 2) DND सेवा बंद करें, 3) कुछ देर रुकें — network issue हो सकता है, 4) सहायता के लिए customer care ${bank.customerCare} पर call करें।`,
  },
  {
    q: `${bank.shortName} balance check के अन्य तरीके क्या हैं?`,
    a: `Missed call के अलावा आप ${bank.name} का बैलेंस ATM से, net banking (${bank.website}) से, mobile app से या passbook update करके भी चेक कर सकते हैं।`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "name": `${bank.shortName} Balance Enquiry — बैलेंस कैसे चेक करें`,
      "description": `${bank.name} से missed call balance enquiry करने की विधि`,
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Registered mobile से call करें", "text": `अपने ${bank.name} में registered mobile number से ${bank.missedCall} पर missed call दें।` },
        { "@type": "HowToStep", "position": 2, "name": "Call कटने का इंतज़ार करें", "text": `2-3 ring के बाद call अपने आप कट जाएगी।` },
        { "@type": "HowToStep", "position": 3, "name": "SMS प्राप्त करें", "text": `कुछ ही सेकंड में SMS में आपका खाता बैलेंस आ जाएगा।` },
      ],
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Balance Enquiry", "item": `${siteUrl}/balance-enquiry/` },
        { "@type": "ListItem", "position": 3, "name": bank.shortName, "item": canonicalUrl },
      ],
    },
  ],
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-3xl mx-auto px-4 py-6">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <a href="/balance-enquiry/" class="hover:text-brand-600">Balance Enquiry</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">{bank.shortName}</span>
    </nav>

    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-1">{bank.shortName} Balance Enquiry</h1>
      <p class="text-brand-100 text-sm">{bank.nameHindi} — मिस्ड कॉल से बैलेंस चेक करें</p>
    </div>

    <!-- Balance Enquiry CTA -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📞 बैलेंस एन्क्वायरी करें</h2>
      <p class="text-gray-600 text-sm mb-4">
        अपने registered mobile number से नीचे दिए गए number पर missed call दें।
        SMS में आपका खाता बैलेंस आ जाएगा।
      </p>
      <a href={`tel:${bank.missedCall}`}
         class="inline-flex items-center gap-2 bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-brand-700 transition-colors">
        <span>📞 {bank.missedCall}</span>
      </a>
      {bank.missedCallAlt && (
        <p class="text-xs text-gray-500 mt-3">
          वैकल्पिक नंबर: <a href={`tel:${bank.missedCallAlt}`} class="text-brand-700 font-medium">{bank.missedCallAlt}</a>
        </p>
      )}
    </div>

    <!-- Steps -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">📝 बैलेंस कैसे चेक करें?</h2>
      <ol class="space-y-3 text-sm text-gray-700">
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <span>सुनिश्चित करें कि आपका mobile number {bank.name} में registered है</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <span>Registered mobile से {bank.missedCall} पर missed call दें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <span>2-3 ring में call कट जाएगी</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">4</span>
          <span>कुछ ही सेकंड में SMS में बैलेंस आ जाएगा</span>
        </li>
      </ol>
    </div>

    <!-- Alternative Methods -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📋 बैलेंस चेक के अन्य तरीके</h2>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-2"><span class="text-brand-600">✓</span> ATM से — card डालकर balance check करें</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Net banking — <a href={bank.website} target="_blank" rel="noopener noreferrer" class="text-brand-700 font-medium">{bank.shortName} net banking</a> में login करके</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Mobile app — {bank.shortName} की official mobile app से</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Passbook update — branch में passbook print कराएं</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> SMS banking — अगर SMS banking सेवा active है तो SMS करके बैलेंस पाएं</li>
      </ul>
    </div>

    <!-- FAQ -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">❓ अक्सर पूछे जाने वाले प्रश्न</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border-b border-gray-100 pb-4 last:border-0">
            <h3 class="font-medium text-gray-900 text-sm mb-2">{faq.q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Related Links -->
    <div class="grid grid-cols-2 gap-3 mb-6">
      <a href={`/bank/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">📞 Balance Check</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Details →</p>
      </a>
      <a href={`/customer-care/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">🎧 Customer Care</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Helpline →</p>
      </a>
    </div>

    <!-- Customer Care -->
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-500 font-medium mb-1">🎧 सहायता के लिए Customer Care</p>
      <a href={`tel:${bank.customerCare}`}
         class="text-lg font-semibold text-brand-700">{bank.customerCare}</a>
    </div>
  </div>
</Layout>
