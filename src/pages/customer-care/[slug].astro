---
import Layout from '../../layouts/Layout.astro';
import { banks, categoryHindi } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map(bank => ({
    params: { slug: bank.slug },
    props: { bank },
  }));
}

interface Props { bank: Bank }
const { bank } = Astro.props;
const isMissedCall = bank.balanceMode === 'missed-call';

const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/customer-care/${bank.slug}/`;
const bankUrl = `${siteUrl}/bank/${bank.slug}/`;
const catSlug = bank.category.toLowerCase().replace(/\s+/g, '-');

const related = banks
  .filter(b => b.category === bank.category && b.slug !== bank.slug)
  .slice(0, 4);

const faqs = [
  {
    q: `${bank.shortName} customer care number क्या है?`,
    a: `${bank.name} (${bank.shortName}) का customer care number ${bank.customerCare} है। बैंकिंग समस्या, balance enquiry, card blocking या account help के लिए इस नंबर पर संपर्क करें।`,
  },
  {
    q: `${bank.nameHindi} में बैलेंस enquiry काम नहीं कर रही तो क्या करें?`,
    a: isMissedCall ? `पहले जांचें कि mobile registered है। ${bank.missedCall} पर missed call के बाद SMS नहीं आए तो ${bank.customerCare} पर संपर्क करें।` : `${bank.missedCall} Customer Care / IVR number है। Call करके balance enquiry विकल्प चुनें या bank representative से सहायता लें।`,
  },
  {
    q: `${bank.shortName} की आधिकारिक वेबसाइट क्या है?`,
    a: `${bank.name} की आधिकारिक वेबसाइट ${bank.website} है। किसी भी नंबर या सेवा को इस्तेमाल करने से पहले official website पर जानकारी cross-check कर लें।`,
  },
  {
    q: `क्या BalCheck customer care सेवा देता है?`,
    a: `नहीं। BalCheck.in सिर्फ bank missed call balance और customer care numbers की directory है। Account, KYC, card या transaction issue के लिए सीधे अपने बैंक से संपर्क करें।`,
  },
];

const phoneSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `${bank.name} Customer Care Number`,
  description: `${bank.name} customer care number ${bank.customerCare} और balance enquiry number ${bank.missedCall}.`,
  url: canonicalUrl,
  mainEntity: {
    '@type': 'BankOrCreditUnion',
    name: bank.name,
    alternateName: bank.shortName,
    telephone: bank.customerCare,
    url: bank.website,
    areaServed: { '@type': 'Country', name: 'India' },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Customer Care', item: `${siteUrl}/customer-care/` },
    { '@type': 'ListItem', position: 3, name: `${bank.shortName} Customer Care`, item: canonicalUrl },
  ],
};

const pageTitle = `${bank.nameHindi} Customer Care Number ${bank.customerCare} | ${bank.shortName} Helpline`;
const pageDesc = `${bank.name} (${bank.shortName}) customer care number ${bank.customerCare}. Balance enquiry number ${bank.missedCall}, official website और help details एक जगह।`;
---

<Layout title={pageTitle} description={pageDesc}>
<script type="application/ld+json" set:html={JSON.stringify(phoneSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<nav class="max-w-4xl mx-auto px-4 pt-4" aria-label="Breadcrumb">
  <ol class="flex items-center gap-1.5 text-sm text-gray-500 flex-wrap">
    <li><a href="/" class="inline-block py-1.5 px-2 -ml-2 rounded-lg hover:text-brand-600 hover:bg-gray-100 active:bg-gray-200 transition-colors">होम</a></li>
    <li aria-hidden="true" class="text-gray-400">›</li>
    <li><a href="/customer-care/" class="inline-block py-1.5 px-1 rounded-lg hover:text-brand-600 hover:bg-gray-100 active:bg-gray-200 transition-colors">Customer Care</a></li>
    <li aria-hidden="true" class="text-gray-400">›</li>
    <li class="text-gray-900 font-medium py-1.5 px-1">{bank.shortName}</li>
  </ol>
</nav>

<section class="bg-gradient-to-b from-brand-50 to-white border-b border-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-6 sm:py-8">
    <p class="text-sm font-medium text-brand-700 mb-2">Bank Helpline</p>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{bank.nameHindi} Customer Care Number</h1>
    <p class="text-sm text-gray-600 mt-2">{bank.name} · {categoryHindi[bank.category]}</p>

    <div class="mt-6 bg-white rounded-2xl border-2 border-brand-200 p-5 shadow-sm">
      <p class="text-sm text-brand-700 font-medium mb-1">🎧 Customer Care Number</p>
      <a href={`tel:${bank.customerCare}`} class="block">
        <span class="text-3xl sm:text-4xl font-bold text-brand-700 tracking-wide">{bank.customerCare}</span>
      </a>
      <a
        href={`tel:${bank.customerCare}`}
        class="mt-4 w-full flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white font-medium py-3.5 rounded-xl transition-colors text-base min-h-[48px]"
      >
        अभी कॉल करें
      </a>
    </div>
  </div>
</section>

<main class="max-w-4xl mx-auto px-4 py-8">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <a href={`/bank/${bank.slug}/`} class="bg-white rounded-xl border border-gray-200 p-4 hover:border-brand-300 transition-colors">
      <p class="text-xs text-gray-500 font-medium mb-1">📞 {isMissedCall ? 'Missed Call Balance Number' : 'Customer Care / IVR Balance Enquiry'}</p>
      <span class="text-xl font-bold text-gray-900">{bank.missedCall}</span>
      <p class="text-xs text-brand-600 mt-2">Balance check page देखें →</p>
    </a>
    <a href={bank.website} target="_blank" rel="noopener" class="bg-white rounded-xl border border-gray-200 p-4 hover:border-brand-300 transition-colors">
      <p class="text-xs text-gray-500 font-medium mb-1">🌐 Official Website</p>
      <span class="text-sm font-bold text-brand-600 break-all">{bank.website.replace('https://www.', '').replace('https://', '')}</span>
    </a>
  </div>

  <section class="mt-8 bg-white rounded-2xl border border-gray-200 p-5">
    <h2 class="text-xl font-bold text-gray-900 mb-4">{bank.shortName} customer care पर कब कॉल करें?</h2>
    <ul class="space-y-3 text-sm text-gray-700">
      <li>• Missed call balance SMS नहीं आया</li>
      <li>• मोबाइल नंबर बैंक खाते से लिंक या update करना है</li>
      <li>• ATM/debit card block या transaction issue है</li>
      <li>• Net banking, UPI या account service में दिक्कत है</li>
    </ul>
  </section>

  <section class="mt-8 bg-amber-50 rounded-2xl border border-amber-200 p-5">
    <h2 class="text-lg font-bold text-amber-900 mb-2">Safety note</h2>
    <p class="text-sm text-amber-800 leading-relaxed">किसी भी call पर OTP, PIN, CVV, UPI PIN या net banking password न बताएं। Bank कभी भी ये details फोन पर नहीं मांगता।</p>
  </section>
</main>

<section class="bg-gray-50 border-t border-gray-100">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <h2 class="text-xl font-bold text-gray-900 text-center mb-6">{bank.shortName} Customer Care — FAQ</h2>
    <div class="space-y-3">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center gap-2">
            {faq.q}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-600 leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

{related.length > 0 && (
  <section class="bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <h2 class="text-lg font-bold text-gray-900 mb-4">{categoryHindi[bank.category]} — अन्य customer care numbers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {related.map(rb => (
          <a href={`/customer-care/${rb.slug}/`} class="flex items-center justify-between bg-white rounded-lg border border-gray-200 p-4 hover:border-brand-300 hover:shadow-sm active:bg-gray-50 transition-all min-h-[56px]">
            <div>
              <p class="font-semibold text-gray-900 text-sm">{rb.nameHindi}</p>
              <p class="text-xs text-gray-500">{rb.shortName}</p>
            </div>
            <span class="text-sm font-bold text-brand-600">{rb.customerCare}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<footer class="bg-gray-50 border-t border-gray-200">
  <div class="max-w-4xl mx-auto px-4 py-6">
    <p class="text-xs text-gray-500 leading-relaxed">BalCheck.in बैंक नहीं है। हम public bank contact directory हैं। Account-specific help के लिए official bank customer care या branch से संपर्क करें।</p>
  </div>
</footer>
</Layout>
