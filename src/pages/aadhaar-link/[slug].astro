---
import Layout from '../../layouts/Layout.astro';
import { banks } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map((bank: Bank) => ({
    params: { slug: bank.slug },
    props: { bank },
  }));
}

interface Props {
  bank: Bank;
}

const { bank } = Astro.props;
const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/aadhaar-link/${bank.slug}/`;

const title = `${bank.shortName} Aadhaar Link — ${bank.nameHindi} आधार लिंक कैसे करें`;
const description = `${bank.name} account में Aadhaar link करने के तरीके। Net banking, SMS, ATM या branch जाकर आधार लिंक करें। ${bank.shortName} Aadhaar seeding online।`;

const faqs = [
  {
    q: `${bank.shortName} account में Aadhaar कैसे link करें?`,
    a: `${bank.name} account में Aadhaar link करने के 4 तरीके हैं: 1) Net banking में login करके "Aadhaar Linking" option से, 2) ATM में जाकर "Aadhaar Seeding" option से, 3) Branch में जाकर Aadhaar seeding form भरकर, 4) SMS के ज़रिए (अगर बैंक SMS सेवा देता है)। सबसे आसान तरीका net banking है।`,
  },
  {
    q: `क्या Aadhaar link करना ज़रूरी है?`,
    a: `हाँ, RBI के अनुसार सभी bank accounts को Aadhaar से link करना ज़रूरी है। बिना Aadhaar linking के आपको scheme benefits, subsidy direct transfer, LPG subsidy और कई सरकारी योजनाओं का लाभ नहीं मिल सकता। ${bank.shortName} में भी Aadhaar linking mandatory है।`,
  },
  {
    q: `${bank.shortName} Aadhaar link करने में कितना समय लगता है?`,
    a: `Net banking या ATM से Aadhaar link करने पर तुरंत request submit हो जाती है। Verification में 24-48 घंटे लगते हैं। Branch से कराने पर 5-7 कार्य दिवस लग सकते हैं। लिंक होने की जानकारी आपके registered mobile पर SMS आती है।`,
  },
  {
    q: `Aadhaar link है या नहीं कैसे check करें?`,
    a: `${bank.shortName} में Aadhaar link है या नहीं check करने के लिए: 1) Net banking में "Aadhaar Status" देखें, 2) UIDAI की वेबसाइट myaadhaar.uidai.gov.in पर जाकर "Bank Seeding Status" check करें, 3) Branch में जाकर पूछें, 4) Customer care ${bank.customerCare} पर call करें।`,
  },
  {
    q: `Aadhaar link नहीं हो रहा तो क्या करें?`,
    a: `अगर Aadhaar link नहीं हो रहा तो: 1) Check करें कि आपके Aadhaar और bank account में नाम और mobile number match करते हैं, 2) ATM से कोशिश करें, 3) ${bank.website} पर net banking से कोशिश करें, 4) Nearest ${bank.shortName} branch में जाकर form भरें, 5) Customer care ${bank.customerCare} पर संपर्क करें।`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "name": `${bank.shortName} Account में Aadhaar Link कैसे करें`,
      "description": `${bank.name} account में Aadhaar link करने की विधि — net banking, ATM, branch या SMS से`,
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Net banking में login करें", "text": `${bank.website} पर जाकर अपने net banking account में login करें।` },
        { "@type": "HowToStep", "position": 2, "name": "Aadhaar Linking option ढूंढें", "text": `"My Profile" या "Service Requests" में जाकर "Aadhaar Linking" या "Aadhaar Seeding" option select करें।` },
        { "@type": "HowToStep", "position": 3, "name": "Aadhaar number डालें", "text": `अपना 12-digit Aadhaar number दर्ज करें और submit करें।` },
        { "@type": "HowToStep", "position": 4, "name": "OTP verify करें", "text": `आपके registered mobile पर OTP आएगा। OTP डालकर verify करें।` },
        { "@type": "HowToStep", "position": 5, "name": "Confirmation का इंतज़ार करें", "text": `24-48 घंटे में Aadhaar link हो जाएगा। SMS में confirmation आती है।` },
      ],
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Aadhaar Link", "item": `${siteUrl}/aadhaar-link/` },
        { "@type": "ListItem", "position": 3, "name": bank.shortName, "item": canonicalUrl },
      ],
    },
  ],
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-3xl mx-auto px-4 py-6">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <a href="/aadhaar-link/" class="hover:text-brand-600">Aadhaar Link</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">{bank.shortName}</span>
    </nav>

    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-1">{bank.shortName} Aadhaar Link</h1>
      <p class="text-brand-100 text-sm">{bank.nameHindi} — आधार लिंक कैसे करें</p>
    </div>

    <!-- CTA -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">🔗 Aadhaar Link करें</h2>
      <p class="text-gray-600 text-sm mb-4">
        {bank.name} account में Aadhaar link करने के लिए net banking या ATM का उपयोग करें।
        यह सेवा मुफ़्त है।
      </p>
      <a href={bank.website}
         target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-brand-700 transition-colors">
        <span>🌐 {bank.shortName} Net Banking →</span>
      </a>
      <p class="text-xs text-gray-500 mt-3">
        अगर net banking नहीं है तो nearest branch में जाकर Aadhaar seeding form भरें।
        सहायता के लिए <a href={`tel:${bank.customerCare}`} class="text-brand-700 font-medium">{bank.customerCare}</a> पर call करें।
      </p>
    </div>

    <!-- Steps -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">📝 Aadhaar Link कैसे करें?</h2>
      <ol class="space-y-3 text-sm text-gray-700">
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <span>{bank.website} पर net banking में login करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <span>"My Profile" या "Service Requests" → "Aadhaar Linking" select करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <span>अपना 12-digit Aadhaar number दर्ज करें और submit करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">4</span>
          <span>Registered mobile पर आए OTP को verify करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">5</span>
          <span>24-48 घंटे में Aadhaar link हो जाएगा — SMS में confirmation आती है</span>
        </li>
      </ol>
    </div>

    <!-- Alternative Methods -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📋 Aadhaar Link के अन्य तरीके</h2>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-2"><span class="text-brand-600">✓</span> ATM से — card डालकर "Aadhaar Seeding" option select करें</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Branch में जाकर Aadhaar seeding form भरें (5-7 दिन)</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Mobile app — {bank.shortName} की official app से</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> SMS — अगर बैंक SMS seeding सेवा देता है (format बैंक के अनुसार)</li>
      </ul>
    </div>

    <!-- FAQ -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">❓ अक्सर पूछे जाने वाले प्रश्न</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border-b border-gray-100 pb-4 last:border-0">
            <h3 class="font-medium text-gray-900 text-sm mb-2">{faq.q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Related Links -->
    <div class="grid grid-cols-2 gap-3 mb-6">
      <a href={`/bank/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">📞 Missed Call Balance</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Balance Check →</p>
      </a>
      <a href={`/customer-care/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">🎧 Customer Care</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Helpline →</p>
      </a>
    </div>

    <!-- Customer Care -->
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-500 font-medium mb-1">🎧 सहायता के लिए Customer Care</p>
      <a href={`tel:${bank.customerCare}`}
         class="text-lg font-semibold text-brand-700">{bank.customerCare}</a>
    </div>
  </div>
</Layout>
