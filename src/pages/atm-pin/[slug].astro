---
import Layout from '../../layouts/Layout.astro';
import { banks } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map((bank: Bank) => ({
    params: { slug: bank.slug },
    props: { bank },
  }));
}

interface Props {
  bank: Bank;
}

const { bank } = Astro.props;
const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/atm-pin/${bank.slug}`;

const title = `${bank.shortName} ATM PIN Generate — ${bank.nameHindi} Green PIN Online`;
const description = `${bank.name} ATM PIN generate करने के तरीके। Net banking, ATM, SMS या customer care से Green PIN generate करें। ${bank.shortName} debit card PIN online।`;

const faqs = [
  {
    q: `${bank.shortName} ATM PIN कैसे generate करें?`,
    a: `${bank.name} ATM PIN generate करने के 4 तरीके हैं: 1) Net banking में login करके "ATM PIN Generation" से, 2) ATM में जाकर "Green PIN" या "PIN Generation" option से, 3) SMS के ज़रिए (अगर बैंक सेवा देता है), 4) Customer care ${bank.customerCare} पर call करके OTP लेकर। सबसे आसान तरीका net banking है।`,
  },
  {
    q: `${bank.shortName} Green PIN क्या है?`,
    a: `Green PIN एक paperless तरीका है जिससे आप बिना branch जाए ATM PIN generate कर सकते हैं। ${bank.name} में net banking या ATM से Green PIN generate करके OTP लेते हैं, फिर उस OTP से ATM में नया PIN set करते हैं। यह सेवा मुफ़्त है।`,
  },
  {
    q: `ATM PIN generate करने के लिए क्या ज़रूरी है?`,
    a: `${bank.shortName} ATM PIN generate करने के लिए ज़रूरी है: 1) Active debit card, 2) Registered mobile number (OTP के लिए), 3) Net banking login (अगर online कर रहे हैं), 4) Account number। बिना registered mobile के PIN generate नहीं होगा।`,
  },
  {
    q: `ATM PIN भूल गए तो क्या करें?`,
    a: `अगर ${bank.shortName} ATM PIN भूल गए हैं तो: 1) Net banking से नया PIN generate करें, 2) ATM में "Green PIN" option से नया PIN set करें, 3) Customer care ${bank.customerCare} पर call करें, 4) Branch में जाकर नया PIN request करें। नया PIN तुरंत set हो जाता है।`,
  },
  {
    q: `क्या ATM PIN generate करने का charge लगता है?`,
    a: `नहीं, ${bank.name} में ATM PIN generate करना मुफ़्त है। Green PIN या net banking से PIN generate करने पर कोई charge नहीं लगता। अगर branch से नया debit card issue कराते हैं तो उसका charge लग सकता है, लेकिन PIN generation मुफ़्त है।`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "name": `${bank.shortName} ATM PIN Generate कैसे करें`,
      "description": `${bank.name} debit card ATM PIN generate करने की विधि — net banking, ATM, या customer care से`,
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Net banking में login करें", "text": `${bank.website} पर जाकर अपने net banking account में login करें।` },
        { "@type": "HowToStep", "position": 2, "name": "ATM PIN Generation option ढूंढें", "text": `"Cards" या "Debit Card" section में जाकर "ATM PIN Generation" या "Green PIN" option select करें।` },
        { "@type": "HowToStep", "position": 3, "name": "OTP verify करें", "text": `आपके registered mobile पर OTP आएगा। OTP डालकर verify करें।` },
        { "@type": "HowToStep", "position": 4, "name": "ATM पर जाएं", "text": `नजदीकी ${bank.shortName} ATM पर जाकर debit card डालें और "Green PIN" या "PIN Generation" option select करें।` },
        { "@type": "HowToStep", "position": 5, "name": "नया PIN set करें", "text": `OTP डालें और अपना नया 4-digit PIN set करें। PIN तुरंत active हो जाएगा।` },
      ],
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "ATM PIN", "item": `${siteUrl}/atm-pin` },
        { "@type": "ListItem", "position": 3, "name": bank.shortName, "item": canonicalUrl },
      ],
    },
  ],
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-3xl mx-auto px-4 py-6">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <a href="/atm-pin" class="hover:text-brand-600">ATM PIN</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">{bank.shortName}</span>
    </nav>

    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-1">{bank.shortName} ATM PIN Generate</h1>
      <p class="text-brand-100 text-sm">{bank.nameHindi} — Green PIN ऑनलाइन</p>
    </div>

    <!-- CTA -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">🔑 ATM PIN Generate करें</h2>
      <p class="text-gray-600 text-sm mb-4">
        {bank.name} debit card का ATM PIN net banking या ATM से generate करें।
        Green PIN सेवा मुफ़्त है।
      </p>
      <a href={bank.website}
         target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-brand-700 transition-colors">
        <span>🌐 {bank.shortName} Net Banking →</span>
      </a>
      <p class="text-xs text-gray-500 mt-3">
        अगर net banking नहीं है तो ATM से "Green PIN" option select करें या
        customer care <a href={`tel:${bank.customerCare}`} class="text-brand-700 font-medium">{bank.customerCare}</a> पर call करें।
      </p>
    </div>

    <!-- Steps -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">📝 ATM PIN Generate कैसे करें?</h2>
      <ol class="space-y-3 text-sm text-gray-700">
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <span>{bank.website} पर net banking में login करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <span>"Cards" → "ATM PIN Generation" या "Green PIN" select करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <span>Registered mobile पर आए OTP को verify करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">4</span>
          <span>नजदीकी {bank.shortName} ATM पर जाकर debit card डालें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">5</span>
          <span>"Green PIN" option में OTP डालें और नया 4-digit PIN set करें</span>
        </li>
      </ol>
    </div>

    <!-- Alternative Methods -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📋 PIN Generate के अन्य तरीके</h2>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-2"><span class="text-brand-600">✓</span> ATM से — card डालकर "PIN Generation" option select करें</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Customer care — {bank.customerCare} पर call करके OTP लें</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Mobile app — {bank.shortName} की official mobile app से</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Branch — nearest branch में जाकर request करें</li>
      </ul>
    </div>

    <!-- FAQ -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">❓ अक्सर पूछे जाने वाले प्रश्न</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border-b border-gray-100 pb-4 last:border-0">
            <h3 class="font-medium text-gray-900 text-sm mb-2">{faq.q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Related Links -->
    <div class="grid grid-cols-2 gap-3 mb-6">
      <a href={`/bank/${bank.slug}`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">📞 Missed Call Balance</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Balance Check →</p>
      </a>
      <a href={`/customer-care/${bank.slug}`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">🎧 Customer Care</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Helpline →</p>
      </a>
    </div>

    <!-- Customer Care -->
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-500 font-medium mb-1">🎧 सहायता के लिए Customer Care</p>
      <a href={`tel:${bank.customerCare}`}
         class="text-lg font-semibold text-brand-700">{bank.customerCare}</a>
    </div>
  </div>
</Layout>
