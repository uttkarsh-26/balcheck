---
import Layout from '../layouts/Layout.astro';
import { banks } from '../data/banks';

const siteUrl = 'https://balcheck.in';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'मिस्ड कॉल से बैंक बैलेंस कैसे चेक करें',
  description: 'बैंक खाते का बैलेंस मिस्ड कॉल से चेक करने के लिए संपूर्ण गाइड।',
  step: [
    { '@type': 'HowToStep', name: 'रजिस्टर्ड मोबाइल नंबर इस्तेमाल करें', text: 'अपने बैंक खाते से लिंक मोबाइल नंबर से ही कॉल करें। यह नंबर बैंक में रजिस्टर्ड होना चाहिए।' },
    { '@type': 'HowToStep', name: 'बैंक के मिस्ड कॉल नंबर पर कॉल करें', text: 'अपने बैंक के missed call balance number पर कॉल करें। नंबर balcheck.in पर खोजें।' },
    { '@type': 'HowToStep', name: '2-3 ring के बाद कॉल कटने दें', text: 'कॉल 2-3 ring के बाद अपने आप कट जाएगी। आपको कोई charge नहीं देना।' },
    { '@type': 'HowToStep', name: 'SMS के लिए इंतज़ार करें', text: 'कुछ सेकंड में आपके मोबाइल पर SMS आ जाएगा जिसमें आपका खाता बैलेंस होगा।' },
    { '@type': 'HowToStep', name: 'समस्या हो तो Customer Care से संपर्क करें', text: 'अगर SMS नहीं आता तो जांचें कि आपका नंबर बैंक में रजिस्टर्ड है या नहीं। फिर भी समस्या हो तो bank customer care से संपर्क करें।' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'मिस्ड कॉल से बैलेंस चेक करने के लिए क्या चाहिए?', acceptedAnswer: { '@type': 'Answer', text: 'आपको बस एक रजिस्टर्ड मोबाइल नंबर चाहिए जो आपके बैंक खाते से लिंक हो। फिर आप बैंक के missed call number पर कॉल करके बैलेंस जान सकते हैं।' } },
    { '@type': 'Question', name: 'क्या मिस्ड कॉल बैलेंस सेवा मुफ़्त है?', acceptedAnswer: { '@type': 'Answer', text: 'हाँ, सभी बैंकों की missed call balance enquiry सेवा बिल्कुल मुफ़्त है। कोई charge नहीं लगता।' } },
    { '@type': 'Question', name: 'SMS नहीं आया तो क्या करें?', acceptedAnswer: { '@type': 'Answer', text: 'जांचें: (1) आपका नंबर बैंक में रजिस्टर्ड है या नहीं, (2) DND सेवा तो चालू नहीं, (3) सही नंबर पर कॉल कर रहे हैं। फिर भी समस्या हो तो customer care से संपर्क करें।' } },
    { '@type': 'Question', name: 'मोबाइल नंबर कैसे रजिस्टर्ड करें?', acceptedAnswer: { '@type': 'Answer', text: 'अपनी बैंक शाखा में जाकर KYC form भरें या ATM से मोबाइल नंबर रजिस्टर करें। कुछ बैंकों में net banking या mobile app से भी नंबर रजिस्टर किया जा सकता है।' } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'How It Works', item: `${siteUrl}/how-it-works/` },
  ],
};

const pageTitle = 'मिस्ड कॉल से बैंक बैलेंस कैसे चेक करें — पूरा गाइड | BalCheck.in';
const pageDesc = 'मिस्ड कॉल से बैंक खाते का बैलेंस चेक करने के लिए संपूर्ण गाइड। नंबर रजिस्टर करने से लेकर SMS प्राप्त करने तक — सब कुछ हिंदी में। मुफ़्त और 24×7।';
---

<Layout title={pageTitle} description={pageDesc}>
<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<!-- Breadcrumb -->
<nav class="max-w-3xl mx-auto px-4 pt-4" aria-label="Breadcrumb">
  <ol class="flex items-center gap-1.5 text-sm text-gray-500">
    <li><a href="/" class="inline-block py-1.5 px-2 -ml-2 rounded-lg hover:text-brand-600 hover:bg-gray-100 active:bg-gray-200 transition-colors">होम</a></li>
    <li aria-hidden="true" class="text-gray-400">›</li>
    <li class="text-gray-900 font-medium py-1.5 px-1">कैसे काम करता है</li>
  </ol>
</nav>

<!-- Hero -->
<section class="bg-gradient-to-b from-brand-50 to-white border-b border-gray-100">
  <div class="max-w-3xl mx-auto px-4 py-8 text-center">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">मिस्ड कॉल से बैंक बैलेंस कैसे चेक करें</h1>
    <p class="mt-3 text-gray-600">बैंक खाते का बैलेंस मिस्ड कॉल से चेक करने के लिए संपूर्ण गाइड — आसान भाषा में</p>
  </div>
</section>

<!-- Steps -->
<section class="max-w-3xl mx-auto px-4 py-8">
  <div class="space-y-6">
    <div class="flex gap-4">
      <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg shrink-0">1</div>
      <div>
        <h2 class="font-bold text-gray-900 text-lg">रजिस्टर्ड मोबाइल नंबर इस्तेमाल करें</h2>
        <p class="text-sm text-gray-600 mt-1">अपने बैंक खाते से लिंक मोबाइल नंबर से ही कॉल करें। �अगर आपका नंबर बैंक में रजिस्टर्ड नहीं है, तो missed call सेवा काम नहीं करेगी। नंबर रजिस्टर करने के लिए बैंक शाखा में जाएं या ATM का इस्तेमाल करें।</p>
      </div>
    </div>
    <div class="flex gap-4">
      <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg shrink-0">2</div>
      <div>
        <h2 class="font-bold text-gray-900 text-lg">बैंक के मिस्ड कॉल नंबर पर कॉल करें</h2>
        <p class="text-sm text-gray-600 mt-1">अपने बैंक का missed call balance number खोजें। <a href="/" class="text-brand-600 underline">BalCheck.in</a> पर सभी बैंकों के नंबर उपलब्ध हैं। उस नंबर पर अपने रजिस्टर्ड मोबाइल से कॉल करें।</p>
      </div>
    </div>
    <div class="flex gap-4">
      <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg shrink-0">3</div>
      <div>
        <h2 class="font-bold text-gray-900 text-lg">2-3 ring के बाद कॉल कटने दें</h2>
        <p class="text-sm text-gray-600 mt-1">कॉल 2-3 ring के बाद अपने आप कट जाएगी। आपको कोई charge नहीं देना। यह सेवा बिल्कुल मुफ़्त है। कॉल काटने के बाद आपको रुकना होगा।</p>
      </div>
    </div>
    <div class="flex gap-4">
      <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg shrink-0">4</div>
      <div>
        <h2 class="font-bold text-gray-900 text-lg">SMS में बैलेंस प्राप्त करें</h2>
        <p class="text-sm text-gray-600 mt-1">कुछ सेकंड में आपके मोबाइल पर SMS आ जाएगा जिसमें आपका खाता बैलेंस होगा। SMS में आपके खाते का current balance और available balance दोनों दिखाए जाएंगे।</p>
      </div>
    </div>
    <div class="flex gap-4">
      <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg shrink-0">5</div>
      <div>
        <h2 class="font-bold text-gray-900 text-lg">समस्या हो तो Customer Care से संपर्क करें</h2>
        <p class="text-sm text-gray-600 mt-1">अगर SMS नहीं आता, तो जांचें: (1) आपका नंबर बैंक में रजिस्टर्ड है या नहीं, (2) DND सेवा तो चालू नहीं, (3) आप सही नंबर पर कॉल कर रहे हैं। फिर भी समस्या हो तो बैंक के customer care नंबर पर संपर्क करें।</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="bg-gray-50 border-t border-gray-100">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <h2 class="text-xl font-bold text-gray-900 text-center mb-6">अक्सर पूछे जाने वाले प्रश्न</h2>
    <div class="space-y-3">
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          मिस्ड कॉल से बैलेंस चेक करने के लिए क्या चाहिए?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">आपको बस एक रजिस्टर्ड मोबाइल नंबर चाहिए जो आपके बैंक खाते से लिंक हो। फिर आप बैंक के missed call number पर कॉल करके बैलेंस जान सकते हैं। किसी app या internet की ज़रूरत नहीं।</p>
      </details>
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          क्या मिस्ड कॉल बैलेंस सेवा मुफ़्त है?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">हाँ, सभी बैंकों की missed call balance enquiry सेवा बिल्कुल मुफ़्त है। कोई charge नहीं लगता। न तो कॉल का charge और न ही SMS का।</p>
      </details>
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          SMS नहीं आया तो क्या करें?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">जांचें: (1) आपका नंबर बैंक में रजिस्टर्ड है या नहीं, (2) DND सेवा तो चालू नहीं, (3) सही नंबर पर कॉल कर रहे हैं। फिर भी समस्या हो तो customer care से संपर्क करें।</p>
      </details>
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          मोबाइल नंबर कैसे रजिस्टर्ड करें?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">अपनी बैंक शाखा में जाकर KYC form भरें या ATM से मोबाइल नंबर रजिस्टर करें। कुछ बैंकों में net banking या mobile app से भी नंबर रजिस्टर किया जा सकता है।</p>
      </details>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-brand-600 text-white">
  <div class="max-w-4xl mx-auto px-4 py-8 text-center">
    <h2 class="text-xl font-bold mb-2">अपना बैंक खोजें</h2>
    <p class="text-brand-100 text-sm mb-4">{banks.length}+ बैंकों के मिस्ड कॉल नंबर एक जगह</p>
    <a href="/" class="inline-flex items-center gap-2 bg-white text-brand-600 font-medium px-6 py-3 rounded-xl hover:bg-brand-50 transition-colors">
      सभी बैंक देखें →
    </a>
  </div>
</section>
</Layout>
