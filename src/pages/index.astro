<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  // Search filter
  const search = document.getElementById('search')!;
  const grid = document.getElementById('bank-grid')!;
  const noResults = document.getElementById('no-results')!;
  let activeCat = 'all';

  function filter() {
    const query = (search as HTMLInputElement).value.toLowerCase().trim();
    let visible = 0;
    
    grid.querySelectorAll<HTMLElement>('.bank-card').forEach(card => {
      const name = card.dataset.name || '';
      const cat = card.dataset.cat || '';
      const matchesText = !query || name.includes(query);
      const matchesCat = activeCat === 'all' || cat === activeCat;
      const show = matchesText && matchesCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    
    noResults.classList.toggle('hidden', visible > 0);
  }

  search.addEventListener('input', filter);

  // Category tabs
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cat-btn').forEach(b => {
        b.classList.remove('active', 'bg-brand-600', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-700');
      });
      btn.classList.add('active', 'bg-brand-600', 'text-white');
      btn.classList.remove('bg-gray-100', 'text-gray-700');
      activeCat = (btn as HTMLElement).dataset.cat || 'all';
      filter();
    });
  });
</script>
