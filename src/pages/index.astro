---
import Layout from '../layouts/Layout.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import VideoHeroBanner from '../components/VideoHeroBanner.astro';
import { banks, categories, categoryHindi } from '../data/banks';

const bankCount = banks.length;
const publicCount = banks.filter(b => b.category === 'Public Sector').length;
const privateCount = banks.filter(b => b.category === 'Private Sector').length;
const sfbCount = banks.filter(b => b.category === 'Small Finance Bank').length;
const siteUrl = 'https://balcheck.in';
---

<Layout 
  title="बैंक बैलेंस मिस्ड कॉल नंबर — सभी बैंकों के Balance Check Numbers | BalCheck.in"
  description="अपने बैंक का बैलेंस जानने के लिए मिस्ड कॉल दें। SBI, HDFC, ICICI, PNB सहित 50+ बैंकों के missed call balance enquiry numbers एक जगह। मुफ़्त और तुरंत।"
>
<SchemaOrg />

<!-- Header -->
<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-brand-600 to-brand-700 text-white font-bold text-lg">₹</div>
      <div>
        <span class="text-xl font-bold text-gray-900">BalCheck</span>
        <span class="text-brand-600 font-bold">.in</span>
      </div>
    </a>
    <div class="flex items-center gap-2">
      <a href="/how-it-works/" class="text-xs text-gray-600 hover:text-brand-600 transition-colors px-2 py-1 rounded">कैसे?</a>
      <span class="text-xs text-gray-500">{bankCount}+ बैंक</span>
      <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2v1.999A11.954 11.954 0 0010 15.056 11.954 11.954 0 002.166 9V7c0-.68.056-1.35.166-2.001z" clip-rule="evenodd"/></svg>
        मुफ़्त
      </span>
    </div>
  </div>
</header>

<!-- Hero — Video Background -->
<VideoHeroBanner
  src="/videos/balcheck-homepage-hero.mp4"
  poster="/videos/balcheck-poster.jpg"
  title="बैंक बैलेंस मिस्ड कॉल नंबर"
  subtitle={`अपने बैंक का बैलेंस जानने के लिए मिस्ड कॉल दें — सभी बैंकों के नंबर एक जगह`}
/>

<!-- Stats Bar -->
<section class="bg-white border-b border-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-center gap-4 sm:gap-6 text-sm">
    <div class="flex items-center gap-1.5">
      <span class="font-bold text-brand-600">{bankCount}</span>
      <span class="text-gray-500">बैंक</span>
    </div>
    <div class="w-px h-4 bg-gray-300"></div>
    <div class="flex items-center gap-1.5">
      <span class="font-bold text-brand-600">100%</span>
      <span class="text-gray-500">मुफ़्त</span>
    </div>
    <div class="w-px h-4 bg-gray-300"></div>
    <div class="flex items-center gap-1.5">
      <span class="font-bold text-brand-600">24×7</span>
      <span class="text-gray-500">उपलब्ध</span>
    </div>
  </div>
</section>

<!-- Category Quick Links (SEO) -->
<section class="bg-white border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 py-3">
    <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
      <a href="/customer-care/" class="px-4 py-2.5 text-sm font-medium rounded-full bg-brand-50 text-brand-700 hover:bg-brand-100 active:bg-brand-200 whitespace-nowrap transition-colors min-h-[44px] inline-flex items-center">
        🎧 Customer Care
      </a>
      <a href="/net-banking/" class="px-4 py-2.5 text-sm font-medium rounded-full bg-brand-50 text-brand-700 hover:bg-brand-100 active:bg-brand-200 whitespace-nowrap transition-colors min-h-[44px] inline-flex items-center">
        🌐 Net Banking
      </a>
      <a href="/sms-banking/" class="px-4 py-2.5 text-sm font-medium rounded-full bg-brand-50 text-brand-700 hover:bg-brand-100 active:bg-brand-200 whitespace-nowrap transition-colors min-h-[44px] inline-flex items-center">
        📱 SMS Banking
      </a>
      {categories.map(cat => (
        <a href={`/banks/${cat.toLowerCase().replace(/\s+/g, '-')}/`} class="px-4 py-2.5 text-sm font-medium rounded-full bg-gray-100 text-gray-700 hover:bg-brand-100 hover:text-brand-700 active:bg-brand-200 whitespace-nowrap transition-colors min-h-[44px] inline-flex items-center">
          {categoryHindi[cat]} ({banks.filter(b => b.category === cat).length})
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Search + Bank Directory -->
<main class="max-w-6xl mx-auto px-4 py-8">
  <!-- Search -->
  <div class="relative mb-6">
    <input
      id="search"
      type="text"
      placeholder="बैंक का नाम खोजें... (जैसे SBI, HDFC, Canara)"
      class="w-full px-5 py-3.5 pl-12 text-base border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent shadow-sm"
      autocomplete="off"
    />
    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
  </div>

  <!-- Category Tabs -->
  <div id="categories" class="flex gap-2 overflow-x-auto pb-2 mb-6 -mx-4 px-4 scrollbar-hide">
    <button data-cat="all" class="cat-btn active px-4 py-2.5 text-sm font-medium rounded-full bg-brand-600 text-white whitespace-nowrap min-h-[44px]">
      सभी बैंक ({bankCount})
    </button>
    {categories.map(cat => (
      <button data-cat={cat} class="cat-btn px-4 py-2.5 text-sm font-medium rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200 active:bg-gray-300 whitespace-nowrap transition-colors min-h-[44px]">
        {categoryHindi[cat]} ({banks.filter(b => b.category === cat).length})
      </button>
    ))}
  </div>

  <!-- Bank Cards Grid -->
  <div id="bank-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {banks.map(bank => (
      <div class="bank-card" data-name={`${bank.name} ${bank.nameHindi} ${bank.shortName}`.toLowerCase()} data-cat={bank.category}>
        <div class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md hover:border-brand-300 transition-all duration-200">
          <!-- Bank Name -->
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href={`/bank/${bank.slug}/`}>
                <h3 class="font-bold text-gray-900 text-base leading-tight hover:text-brand-600 transition-colors">{bank.nameHindi}</h3>
              </a>
              <p class="text-xs text-gray-500 mt-0.5">{bank.name}</p>
            </div>
            <span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-1 rounded shrink-0">
              {bank.shortName}
            </span>
          </div>

          <!-- Missed Call Number -->
          <a href={`tel:${bank.missedCall}`} class="block">
            <div class="bg-brand-50 rounded-lg p-3 mb-3 hover:bg-brand-100 transition-colors">
              <p class="text-xs text-brand-700 font-medium mb-1">📞 मिस्ड कॉल नंबर</p>
              <span class="text-xl font-bold text-brand-700 tracking-wide">{bank.missedCall}</span>
            </div>
          </a>

          <!-- Actions -->
          <div class="flex items-center gap-2">
            <a
              href={`tel:${bank.missedCall}`}
              class="flex-1 flex items-center justify-center gap-1.5 bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white text-sm font-medium py-2.5 rounded-lg transition-colors min-h-[44px]"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              कॉल करें
            </a>
            <a
              href={`https://wa.me/?text=${encodeURIComponent(`${bank.nameHindi} का बैलेंस चेक नंबर: ${bank.missedCall} — ${siteUrl}/bank/${bank.slug}/`)}`}
              target="_blank"
              rel="noopener"
              class="flex items-center justify-center w-11 h-11 bg-green-50 hover:bg-green-100 active:bg-green-200 text-green-600 rounded-lg transition-colors shrink-0"
              title="WhatsApp पर शेयर करें"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          </div>
          
          {bank.notes && (
            <p class="text-xs text-gray-400 mt-2">⚠️ {bank.notes}</p>
          )}
        </div>
      </div>
    ))}
  </div>

  <!-- No Results -->
  <div id="no-results" class="hidden text-center py-12">
    <p class="text-gray-500 text-lg">कोई बैंक नहीं मिला।</p>
    <p class="text-gray-400 text-sm mt-1">कृपया अलग नाम से खोजें।</p>
  </div>
</main>

<!-- How It Works -->
<section class="bg-white border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h2 class="text-xl font-bold text-gray-900 text-center mb-6">कैसे काम करता है?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="text-center">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg mx-auto mb-3">1</div>
        <h3 class="font-semibold text-gray-900 text-sm mb-1">मिस्ड कॉल दें</h3>
        <p class="text-xs text-gray-500">अपने बैंक के नंबर पर registered mobile से कॉल करें</p>
      </div>
      <div class="text-center">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg mx-auto mb-3">2</div>
        <h3 class="font-semibold text-gray-900 text-sm mb-1">कॉल कट जाएगी</h3>
        <p class="text-xs text-gray-500">2-3 ring के बाद कॉल अपने आप कट जाएगी</p>
      </div>
      <div class="text-center">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-bold text-lg mx-auto mb-3">3</div>
        <h3 class="font-semibold text-gray-900 text-sm mb-1">SMS में बैलेंस</h3>
        <p class="text-xs text-gray-500">कुछ सेकंड में SMS आ जाएगा आपके बैलेंस के साथ</p>
      </div>
    </div>
    <div class="text-center mt-6">
      <a href="/how-it-works/" class="inline-flex items-center gap-1 text-sm font-medium text-brand-600 hover:text-brand-700">
        पूरा गाइड पढ़ें →
      </a>
    </div>
  </div>
</section>

<!-- Banking Services Directory -->
<section class="bg-white border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h2 class="text-xl font-bold text-gray-900 text-center mb-2">बैंकिंग सेवाएं</h2>
    <p class="text-sm text-gray-500 text-center mb-6">अपने बैंक की सभी सेवाएं एक जगह — {bankCount} बैंकों के लिए</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/customer-care/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-sm transition-all text-center">
        <div class="text-3xl mb-2">🎧</div>
        <h3 class="font-semibold text-gray-900 text-sm mb-1">Customer Care</h3>
        <p class="text-xs text-gray-500">सभी बैंकों के helpline नंबर</p>
        <p class="text-xs text-brand-600 font-medium mt-2">{bankCount} बैंक →</p>
      </a>
      <a href="/net-banking/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-sm transition-all text-center">
        <div class="text-3xl mb-2">🌐</div>
        <h3 class="font-semibold text-gray-900 text-sm mb-1">Net Banking</h3>
        <p class="text-xs text-gray-500">Online banking login links</p>
        <p class="text-xs text-brand-600 font-medium mt-2">{bankCount} बैंक →</p>
      </a>
      <a href="/sms-banking/" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-brand-300 hover:shadow-sm transition-all text-center">
        <div class="text-3xl mb-2">📱</div>
        <h3 class="font-semibold text-gray-900 text-sm mb-1">SMS Banking</h3>
        <p class="text-xs text-gray-500">SMS से balance check</p>
        <p class="text-xs text-brand-600 font-medium mt-2">{bankCount} बैंक →</p>
      </a>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="bg-gray-50 border-t border-gray-100">
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h2 class="text-xl font-bold text-gray-900 text-center mb-6">अक्सर पूछे जाने वाले प्रश्न</h2>
    <div class="space-y-3">
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          मिस्ड कॉल से बैलेंस कैसे पता करें?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">अपने बैंक का रजिस्टर्ड मोबाइल नंबर से ऊपर दिए गए missed call number पर कॉल करें और 2-3 ring के बाद कॉल काट दें। कुछ ही सेकंड में आपको SMS में बैलेंस आ जाएगा। यह सेवा बिल्कुल मुफ़्त है।</p>
      </details>
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          क्या मिस्ड कॉल बैलेंस सेवा मुफ़्त है?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">हाँ, सभी बैंकों की missed call balance enquiry सेवा बिल्कुल मुफ़्त है। आपको कोई charge नहीं देना। बस अपना नंबर बैंक में रजिस्टर्ड होना चाहिए।</p>
      </details>
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          मेरा नंबर बैंक में रजिस्टर्ड नहीं है तो?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">अगर आपका मोबाइल नंबर बैंक खाते से लिंक नहीं है, तो missed call सेवा काम नहीं करेगी। अपनी बैंक शाखा में जाकर या ATM से मोबाइल नंबर रजिस्टर करवाएं। इसके बाद missed call सेवा उपलब्ध हो जाएगी।</p>
      </details>
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          SMS नहीं आया तो क्या करें?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">अगर SMS नहीं आता, तो जांचें: (1) आपका नंबर बैंक में रजिस्टर्ड है या नहीं, (2) DND सेवा तो चालू नहीं है, (3) आप सही नंबर पर कॉल कर रहे हैं। फिर भी समस्या हो तो बैंक के customer care से संपर्क करें।</p>
      </details>
      <details class="bg-white rounded-lg border border-gray-200 p-4 group">
        <summary class="font-medium text-gray-900 cursor-pointer list-none flex justify-between items-center">
          क्या ये नंबर सुरक्षित हैं?
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-600">जी हाँ, ये सभी नंबर आधिकारिक बैंक वेबसाइटों से लिए गए हैं। मिस्ड कॉल से आपका कोई पैसा या जानकारी नहीं चली जाती। आपको सिर्फ अपना बैलेंस SMS में मिलता है। फिर भी, हम समय-समय पर नंबर सत्यापित करते हैं।</p>
      </details>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 text-white font-bold">₹</div>
        <span class="font-bold text-white">BalCheck.in</span>
      </div>
      <div class="flex items-center gap-4 text-sm">
        <a href="/" class="text-gray-400 hover:text-white transition-colors">होम</a>
        <a href="/how-it-works/" class="text-gray-400 hover:text-white transition-colors">कैसे काम करता है</a>
        <a href="/customer-care/" class="text-gray-400 hover:text-white transition-colors">Customer Care</a>
        <a href="/net-banking/" class="text-gray-400 hover:text-white transition-colors">Net Banking</a>
        <a href="/sms-banking/" class="text-gray-400 hover:text-white transition-colors">SMS Banking</a>
        <a href="/banks/public-sector/" class="text-gray-400 hover:text-white transition-colors">सरकारी बैंक</a>
        <a href="/banks/private-sector/" class="text-gray-400 hover:text-white transition-colors">निजी बैंक</a>
      </div>
    </div>
    <div class="mt-6 pt-6 border-t border-gray-800">
      <p class="text-xs text-gray-500 leading-relaxed">
