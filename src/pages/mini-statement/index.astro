---
import Layout from '../../layouts/Layout.astro';
import { banks, categories, categoryHindi } from '../../data/banks';

const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/mini-statement`;

const title = 'Bank Mini Statement Number — भारतीय बैंकों के Last 5 Transactions';
const description = `सभी भारतीय बैंकों के mini statement number एक जगह पर। ${banks.length}+ बैंकों से missed call या SMS से last 5 transactions की जानकारी पाएं। मुफ़्त, 24×7।`;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Bank Mini Statement Numbers India",
  "description": description,
  "url": canonicalUrl,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Mini Statement", "item": canonicalUrl },
    ],
  },
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-4xl mx-auto px-4 py-6">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">Mini Statement</span>
    </nav>

    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-2">Mini Statement Directory</h1>
      <p class="text-brand-100 text-sm">भारतीय बैंकों से last 5 transactions की जानकारी — {banks.length} बैंकों के mini statement numbers</p>
    </div>

    <p class="text-gray-600 text-sm mb-6">
      अपने बैंक का mini statement number नीचे खोजें। Missed call देकर SMS में last 5 transactions की जानकारी पाएं।
      यह सेवा मुफ़्त है और 24×7 उपलब्ध है।
    </p>

    {categories.map(cat => {
      const catBanks = banks.filter(b => b.category === cat);
      return (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
            {cat}
            <span class="text-sm font-normal text-gray-500">({categoryHindi[cat]})</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {catBanks.map(bank => (
              <a href={`/mini-statement/${bank.slug}`}
                 class="bg-white rounded-xl border border-gray-200 p-4 hover:border-brand-300 hover:shadow-sm transition-all">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-gray-900 text-sm">{bank.shortName}</p>
                    <p class="text-xs text-gray-500">{bank.nameHindi}</p>
                  </div>
                  <span class="text-brand-600 text-sm">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</Layout>
