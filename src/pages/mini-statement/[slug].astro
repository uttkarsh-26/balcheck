---
import Layout from '../../layouts/Layout.astro';
import { banks } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map((bank: Bank) => ({
    params: { slug: bank.slug },
    props: { bank },
  }));
}

interface Props {
  bank: Bank;
}

const { bank } = Astro.props;
const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/mini-statement/${bank.slug}/`;

const hasDedicatedNumber = !!bank.missedCallAlt;
const miniStatementNumber = hasDedicatedNumber ? bank.missedCallAlt! : bank.missedCall;

// ─── GSC-driven exact-query overrides ─────────────────────────────
// Demand signal (28d GSC): mini-statement cluster = 3,151 impressions.
//   BOI:  440 imp landing /bank/boi + 305+203+107 on /mini-statement/boi
//   Axis: 67+56 imp around positions 10.9–11.9
// Overrides target the exact H1/title/quick-answer text users search for,
// without touching verified phone data or the scalable default template.
interface QueryOverride {
  /** Exact <title> tag text */
  title: string;
  /** Exact <h1> text */
  h1: string;
  /** Visible quick-answer paragraph in the CTA card body */
  quickAnswer: string;
  /** Override for the first FAQ Q (the "what is the number" question) */
  faq1Question: string;
  faq1Answer: string;
  /** Meta description override (avoids claiming unverified numbers) */
  description?: string;
}

const queryOverrides: Record<string, QueryOverride> = {
  boi: {
    title: `BOI Mini Statement Number: ${miniStatementNumber} — Bank of India Last 5 Transactions`,
    h1: 'BOI Mini Statement Number',
    quickAnswer: `BOI (Bank of India) का mini statement number ${miniStatementNumber} है। इस पर registered mobile से missed call देने पर SMS में last 5 transactions की जानकारी तुरंत मिलती है।`,
    faq1Question: 'BOI mini statement number क्या है?',
    faq1Answer: `Bank of India (BOI) का mini statement number ${miniStatementNumber} है। इस पर अपने registered mobile से missed call दें — 2-3 ring में call कट जाएगी और SMS में last 5 transactions की जानकारी आ जाएगी।`,
    description: `Bank of India mini statement: missed call to ${miniStatementNumber} for last 5 transactions. Free BOI mini statement check, 24×7।`,
  },
  axis: {
    title: `Axis Bank Mini Statement — Last 5 Transactions कैसे देखें`,
    h1: 'Axis Bank Mini Statement',
    quickAnswer: `Axis Bank के लिए अलग dedicated mini statement missed-call number official-source data में verified नहीं है। Last 5 transactions के लिए ATM (Mini Statement option), official net banking, या customer care ${bank.customerCare} का उपयोग करें। Balance enquiry number ${bank.missedCall} से केवल balance आता है, mini statement नहीं।`,
    faq1Question: 'Axis Bank mini statement कैसे निकालें?',
    faq1Answer: `Axis Bank के last 5 transactions देखने के लिए ATM में Mini Statement option या official net banking का उपयोग करें। अलग dedicated mini statement missed-call number verified नहीं है; सहायता के लिए ${bank.customerCare} पर संपर्क करें।`,
  },
};

const override = queryOverrides[bank.slug];

// ─── Title / Description ───────────────────────────────────────────
const title = override?.title
  ?? `${bank.shortName} Mini Statement Number — ${bank.nameHindi} Last 5 Transactions`;

const description = override
  ? `${bank.name} mini statement: missed call to ${miniStatementNumber} for last 5 transactions. Free mini statement check, 24×7।`
  : `${bank.name} mini statement: ${hasDedicatedNumber ? `missed call to ${bank.missedCallAlt} for last 5 transactions.` : `missed call to ${bank.missedCall} or use SMS banking.`} Free mini statement check, 24×7।`;

const h1Text = override?.h1 ?? `${bank.shortName} Mini Statement`;

// ─── FAQs (with override for Q1 when present) ──────────────────────
const faq1Q = override?.faq1Question ?? `${bank.shortName} का mini statement number क्या है?`;
const faq1A = override?.faq1Answer ?? (hasDedicatedNumber
  ? `${bank.name} का mini statement number ${bank.missedCallAlt} है। इस पर अपने registered mobile से missed call दें और SMS में last 5 transactions की जानकारी पाएं।`
  : `${bank.name} के लिए mini statement के लिए ${bank.missedCall} पर missed call दें। कुछ बैंकों में balance और mini statement दोनों इसी number पर मिलते हैं। अगर अलग से नहीं मिलता तो ATM या net banking से mini statement देखें।`);

const faqs = [
  { q: faq1Q, a: faq1A },
  {
    q: `Mini statement में क्या जानकारी मिलती है?`,
    a: `Mini statement में आपके account के last 5 transactions की जानकारी होती है — deposit, withdrawal, transfer, UPI, ATM transaction आदि। हर transaction के साथ date और amount लिखा होता है। यह सेवा मुफ़्त है।`,
  },
  {
    q: `${bank.shortName} mini statement के लिए क्या करना होगा?`,
    a: hasDedicatedNumber
      ? `अपने registered mobile से ${bank.missedCallAlt} पर missed call दें। 2-3 ring में कट जाएगी और SMS में last 5 transactions आ जाएंगे।`
      : `अपने registered mobile से ${bank.missedCall} पर missed call दें। अगर mini statement नहीं आता तो ATM में जाकर "Mini Statement" option select करें या ${bank.website} पर net banking से देखें।`,
  },
  {
    q: `क्या mini statement सेवा मुफ़्त है?`,
    a: `हाँ, missed call से mini statement प्राप्त करना पूरी तरह मुफ़्त है। कोई charge नहीं लगता। बस आपका mobile number ${bank.name} में registered होना चाहिए। अगर registered नहीं है तो nearest branch में जाकर mobile number register कराएं।`,
  },
  {
    q: `Mini statement SMS नहीं आया तो क्या करें?`,
    a: `अगर mini statement SMS नहीं आता तो: 1) Check करें कि आपका mobile number ${bank.name} में registered है, 2) कुछ देर रुकें — network issue हो सकता है, 3) ATM से mini statement निकालें, 4) ${bank.website} पर net banking से देखें, 5) सहायता के लिए customer care ${bank.customerCare} पर call करें।`,
  },
];

// ─── Quick answer paragraph (visible in body, aligned with title) ──
const quickAnswerText = override?.quickAnswer ?? (hasDedicatedNumber
  ? `${bank.name} का dedicated mini statement number ${bank.missedCallAlt} है। इस पर registered mobile से missed call दें — SMS में last 5 transactions तुरंत मिलेंगे।`
  : `${bank.name} के लिए ${bank.missedCall} पर missed call दें। अगर mini statement नहीं आता तो ATM या net banking से देखें।`);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "name": `${bank.shortName} Mini Statement कैसे प्राप्त करें`,
      "description": `${bank.name} से mini statement (last 5 transactions) प्राप्त करने की विधि`,
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Registered mobile से call करें", "text": `अपने ${bank.name} में registered mobile number से ${miniStatementNumber} पर missed call दें।` },
        { "@type": "HowToStep", "position": 2, "name": "Call कटने का इंतज़ार करें", "text": `2-3 ring के बाद call अपने आप कट जाएगी।` },
        { "@type": "HowToStep", "position": 3, "name": "SMS प्राप्त करें", "text": `कुछ ही सेकंड में SMS में आपके last 5 transactions की जानकारी आ जाएगी।` },
      ],
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Mini Statement", "item": `${siteUrl}/mini-statement/` },
        { "@type": "ListItem", "position": 3, "name": bank.shortName, "item": canonicalUrl },
      ],
    },
  ],
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-3xl mx-auto px-4 py-6">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <a href="/mini-statement/" class="hover:text-brand-600">Mini Statement</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">{bank.shortName}</span>
    </nav>

    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-1">{h1Text}</h1>
      <p class="text-brand-100 text-sm">{bank.nameHindi} — अंतिम 5 लेन-देन की जानकारी</p>
    </div>

    <!-- Quick Answer + Mini Statement CTA -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📄 Mini Statement प्राप्त करें</h2>
      <!-- Quick answer — visible body text aligned with page title -->
      <p class="text-gray-700 text-sm mb-3 leading-relaxed font-medium">{quickAnswerText}</p>
      <p class="text-gray-600 text-sm mb-4">
        अपने registered mobile number से नीचे दिए गए number पर missed call दें।
        SMS में आपके last 5 transactions की जानकारी आ जाएगी।
      </p>
      <a href={`tel:${miniStatementNumber}`}
         class="inline-flex items-center gap-2 bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-brand-700 transition-colors">
        <span>📞 {miniStatementNumber}</span>
      </a>
      {hasDedicatedNumber ? (
        <p class="text-xs text-gray-500 mt-3">
          यह {bank.shortName} का dedicated mini statement number है। Balance check के लिए <a href={`/bank/${bank.slug}/`} class="text-brand-700 font-medium">{bank.missedCall}</a> पर call करें।
        </p>
      ) : (
        <p class="text-xs text-gray-500 mt-3">
          अगर इस number से mini statement नहीं आता तो ATM या net banking का उपयोग करें। Balance check के लिए भी यही number <a href={`/bank/${bank.slug}/`} class="text-brand-700 font-medium">{bank.missedCall}</a> है।
        </p>
      )}
    </div>

    <!-- Steps -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">📝 Mini Statement कैसे प्राप्त करें?</h2>
      <ol class="space-y-3 text-sm text-gray-700">
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <span>सुनिश्चित करें कि आपका mobile number {bank.name} में registered है</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <span>Registered mobile से {miniStatementNumber} पर missed call दें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <span>2-3 ring में call कट जाएगी</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">4</span>
          <span>कुछ ही सेकंड में SMS में last 5 transactions आ जाएंगे</span>
        </li>
      </ol>
    </div>

    <!-- Alternative Methods -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📋 Mini Statement के अन्य तरीके</h2>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-2"><span class="text-brand-600">✓</span> ATM से — card डालकर "Mini Statement" option select करें</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Net banking — <a href={bank.website} target="_blank" rel="noopener noreferrer" class="text-brand-700 font-medium">{bank.shortName} net banking</a> में login करके</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Mobile app — {bank.shortName} की official mobile app से</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Passbook update — branch में passbook print कराएं</li>
      </ul>
    </div>

    <!-- FAQ -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">❓ अक्सर पूछे जाने वाले प्रश्न</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border-b border-gray-100 pb-4 last:border-0">
            <h3 class="font-medium text-gray-900 text-sm mb-2">{faq.q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Related Links -->
    <div class="grid grid-cols-2 gap-3 mb-3">
      <a href={`/bank/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">📞 Missed Call Balance</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Balance Check →</p>
      </a>
      <a href={`/customer-care/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">🎧 Customer Care</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Helpline →</p>
      </a>
    </div>
    <div class="grid grid-cols-2 gap-3 mb-6">
      <a href={`/sms-banking/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">📱 SMS Banking</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} SMS Services →</p>
      </a>
      <a href={`/balance-enquiry/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">💰 Balance Enquiry</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} All Methods →</p>
      </a>
    </div>

    <!-- Customer Care -->
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-500 font-medium mb-1">🎧 सहायता के लिए Customer Care</p>
      <a href={`tel:${bank.customerCare}`}
         class="text-lg font-semibold text-brand-700">{bank.customerCare}</a>
    </div>
  </div>
</Layout>
