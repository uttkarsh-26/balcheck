---
import Layout from '../../layouts/Layout.astro';
import { banks } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map((bank: Bank) => ({ params: { slug: bank.slug }, props: { bank } }));
}

interface Props { bank: Bank }
const { bank } = Astro.props;
const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/mini-statement/${bank.slug}/`;
const hasDedicatedNumber = Boolean(bank.missedCallAlt);
const transactionCount = bank.slug === 'kvb' ? 3 : 5;
const displayName = ({ axis: 'Axis Bank', federal: 'Federal Bank' } as Record<string, string>)[bank.slug] ?? bank.shortName;
const title = hasDedicatedNumber
  ? `${bank.shortName} Mini Statement Number ${bank.missedCallAlt} | BalCheck`
  : `${displayName} Mini Statement — Official Methods | BalCheck`;
const description = hasDedicatedNumber
  ? `${bank.name} verified mini statement number ${bank.missedCallAlt}. Registered mobile से missed call देकर last ${transactionCount} transactions पाएं।`
  : `${bank.name} का dedicated mini-statement missed-call number verified नहीं है। ATM, official app, net banking या customer care ${bank.customerCare} का उपयोग करें।`;
const h1Text = hasDedicatedNumber ? `${bank.shortName} Mini Statement Number` : `${displayName} Mini Statement`;

const faqs = [
  {
    q: `${bank.shortName} mini statement कैसे प्राप्त करें?`,
    a: hasDedicatedNumber
      ? `Registered mobile से verified number ${bank.missedCallAlt} पर missed call दें। SMS में last ${transactionCount} transactions मिलेंगे।`
      : `Dedicated mini-statement missed-call number verified नहीं है। ${bank.name} की official app, net banking, ATM या customer care ${bank.customerCare} का उपयोग करें।`,
  },
  {
    q: `Mini statement नहीं मिले तो क्या करें?`,
    a: `Official website ${bank.website} पर current instructions देखें या customer care ${bank.customerCare} से पुष्टि करें। OTP, PIN या CVV किसी से share न करें।`,
  },
];

const graph: Record<string, unknown>[] = [
  {
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Mini Statement', item: `${siteUrl}/mini-statement/` },
      { '@type': 'ListItem', position: 3, name: bank.shortName, item: canonicalUrl },
    ],
  },
];
if (hasDedicatedNumber) {
  graph.unshift({
    '@type': 'HowTo',
    name: `${bank.shortName} Mini Statement कैसे प्राप्त करें`,
    description: `${bank.name} के verified dedicated mini-statement number से last ${transactionCount} transactions प्राप्त करें।`,
    step: [
      { '@type': 'HowToStep', position: 1, name: 'Registered mobile से call करें', text: `${bank.missedCallAlt} पर missed call दें।` },
      { '@type': 'HowToStep', position: 2, name: 'SMS प्राप्त करें', text: `SMS में last ${transactionCount} transactions प्राप्त करें।` },
    ],
  });
}
const schema = { '@context': 'https://schema.org', '@graph': graph };
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <div class="max-w-3xl mx-auto px-4 py-6">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/">Home</a><span class="mx-1">›</span><a href="/mini-statement/">Mini Statement</a><span class="mx-1">›</span><span>{bank.shortName}</span>
    </nav>
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-1">{h1Text}</h1>
      <p class="text-brand-100 text-sm">{bank.nameHindi} — हाल के लेन-देन की जानकारी</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      {hasDedicatedNumber ? (
        <>
          <h2 class="text-lg font-semibold mb-3">Verified Mini Statement Number</h2>
          <p class="text-gray-700 text-sm mb-4">{bank.name} का verified dedicated number <strong>{bank.missedCallAlt}</strong> है। Registered mobile से missed call दें; SMS में last {transactionCount} transactions मिलेंगे।</p>
          <a href={`tel:${bank.missedCallAlt}`} class="inline-flex bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium">📞 {bank.missedCallAlt}</a>
        </>
      ) : (
        <>
          <h2 class="text-lg font-semibold mb-3">Official Mini Statement Methods</h2>
          <p class="text-gray-700 text-sm mb-3">{bank.name} का dedicated mini-statement missed-call number verified नहीं है। Balance enquiry number को mini-statement number मानकर call न करें।</p>
          <ul class="space-y-2 text-sm text-gray-700 mb-4">
            <li>✓ Official mobile app या net banking में recent transactions देखें</li>
            <li>✓ ATM में “Mini Statement” विकल्प चुनें</li>
            <li>✓ Official instructions के लिए <a href={bank.website} target="_blank" rel="noopener noreferrer" class="text-brand-700 font-medium">bank website</a> देखें</li>
          </ul>
          <a href={`tel:${bank.customerCare}`} class="inline-flex bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium">Customer Care: {bank.customerCare}</a>
        </>
      )}
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold mb-3">सुरक्षित तरीके</h2>
      <p class="text-sm text-gray-700">केवल official app, website, ATM और bank customer care का उपयोग करें। OTP, ATM PIN, UPI PIN या CVV कभी share न करें।</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold mb-4">अक्सर पूछे जाने वाले प्रश्न</h2>
      <div class="space-y-4">{faqs.map(f => <div><h3 class="font-medium text-sm mb-1">{f.q}</h3><p class="text-gray-600 text-sm">{f.a}</p></div>)}</div>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <a href={`/sms-banking/${bank.slug}/`} class="bg-white rounded-xl border border-gray-200 p-4 text-center text-brand-700">SMS Banking →</a>
      <a href={`/balance-enquiry/${bank.slug}/`} class="bg-white rounded-xl border border-gray-200 p-4 text-center text-brand-700">Balance Enquiry →</a>
    </div>
  </div>
</Layout>
