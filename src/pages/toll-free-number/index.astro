---
import Layout from '../../layouts/Layout.astro';
import { banks, categories, categoryHindi } from '../../data/banks';

const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/toll-free-number/`;

const title = `Bank Toll Free Numbers India — ${banks.length}+ बैंक Helpline | BalCheck.in`;
const description = `SBI, HDFC, ICICI, PNB सहित ${banks.length}+ बैंकों के toll free customer care numbers एक जगह। Official website links और safety tips।`;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Bank Toll Free Numbers India",
  "description": description,
  "url": canonicalUrl,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Toll Free Number", "item": canonicalUrl },
    ],
  },
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-4xl mx-auto px-4 py-6">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">Toll Free Numbers</span>
    </nav>

    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-2">Bank Toll Free Numbers India</h1>
      <p class="text-brand-100 text-sm">भारतीय बैंकों के customer care नंबर — {banks.length} बैंकों के helpline</p>
    </div>

    <div class="bg-amber-50 rounded-2xl border border-amber-200 p-5 mb-6">
      <h2 class="text-lg font-bold text-amber-900 mb-2">⚠️ Safety first</h2>
      <p class="text-sm text-amber-800 leading-relaxed">Customer care call पर OTP, PIN, CVV, UPI PIN या password कभी न बताएं। Bank ये details phone पर नहीं मांगता।</p>
    </div>

    {categories.map(cat => {
      const catBanks = banks.filter(b => b.category === cat);
      return (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
            {cat}
            <span class="text-sm font-normal text-gray-500">({categoryHindi[cat]})</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {catBanks.map(bank => (
              <a href={`/toll-free-number/${bank.slug}/`}
                 class="bg-white rounded-xl border border-gray-200 p-4 hover:border-brand-300 hover:shadow-sm transition-all">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-gray-900 text-sm">{bank.shortName}</p>
                    <p class="text-xs text-gray-500">{bank.nameHindi}</p>
                  </div>
                  <span class="text-xs font-bold text-brand-600">{bank.customerCare}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</Layout>
