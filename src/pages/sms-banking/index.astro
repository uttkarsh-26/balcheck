---
import Layout from '../../layouts/Layout.astro';
import { banks, categories, categoryHindi } from '../../data/banks';

const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/sms-banking/`;

const title = 'SMS Banking Directory — बैंक Balance Check SMS Numbers';
const description = 'सभी भारतीय बैंकों के SMS banking numbers एक जगह पर। Missed call से balance check, mini statement, transaction alert। SBI, HDFC, ICICI और 60+ बैंकों के SMS banking सेवाएं।';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "SMS Banking Directory",
  "description": description,
  "url": canonicalUrl,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "SMS Banking", "item": canonicalUrl },
    ],
  },
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-4xl mx-auto px-4 py-6">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">SMS Banking</span>
    </nav>

    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-2">SMS Banking Directory</h1>
      <p class="text-brand-100 text-sm">भारतीय बैंकों के SMS banking — {banks.length} बैंकों के balance check numbers</p>
    </div>

    <p class="text-gray-600 text-sm mb-6">
      Missed call से account balance check करें। अपने registered mobile से नीचे दिए गए number पर
      missed call दें और SMS में balance पाएं। यह सेवा मुफ़्त है।
    </p>

    {categories.map(cat => {
      const catBanks = banks.filter(b => b.category === cat);
      return (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
            {cat}
            <span class="text-sm font-normal text-gray-500">({categoryHindi[cat]})</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {catBanks.map(bank => (
              <a href={`/sms-banking/${bank.slug}/`}
                 class="bg-white rounded-xl border border-gray-200 p-4 hover:border-brand-300 hover:shadow-sm transition-all">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-gray-900 text-sm">{bank.shortName}</p>
                    <p class="text-xs text-gray-500">{bank.nameHindi}</p>
                  </div>
                  <span class="text-brand-600 text-sm">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</Layout>
