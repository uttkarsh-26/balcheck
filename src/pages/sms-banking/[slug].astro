---
import Layout from '../../layouts/Layout.astro';
import { banks } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map((bank: Bank) => ({
    params: { slug: bank.slug },
    props: { bank },
  }));
}

interface Props {
  bank: Bank;
}

const { bank } = Astro.props;
const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/sms-banking/${bank.slug}/`;

const title = bank.slug === 'punjab-gramin'
  ? `Punjab Gramin Bank Balance Check Number ${bank.missedCall} — SMS Banking`
  : `${bank.shortName} SMS Banking — ${bank.nameHindi} Balance Check by SMS`;
const description = bank.slug === 'punjab-gramin'
  ? `Punjab Gramin Bank balance check number ${bank.missedCall} पर registered mobile से missed call दें और SMS में balance पाएं। मुफ़्त SMS banking guide।`
  : `${bank.name} SMS banking: missed call to ${bank.missedCall} for balance check. SMS services, registration guide, mini statement, transaction alerts. Free SMS banking service।`;

const faqs = [
  {
    q: `${bank.shortName} SMS banking से balance कैसे check करें?`,
    a: `${bank.shortName} account balance जानने के लिए अपने registered mobile number से ${bank.missedCall} पर missed call दें। कुछ ही सेकंड में SMS में आपका balance आ जाएगा। यह सेवा मुफ़्त है।`,
  },
  {
    q: `SMS banking के लिए registration कैसे करें?`,
    a: `SMS banking के लिए आपका mobile number बैंक में registered होना चाहिए। अगर registered नहीं है तो nearest branch में जाकर KYC form भरें या ATM से mobile number register करें। एक बार register होने के बाद ${bank.missedCall} पर missed call देकर balance check करें।`,
  },
  {
    q: `${bank.shortName} का SMS banking number क्या है?`,
    a: `${bank.shortName} का balance check number ${bank.missedCall} है। इस पर missed call देने पर आपको SMS में balance जानकारी मिलती है।${bank.missedCallAlt ? ` Mini statement के लिए ${bank.missedCallAlt} पर missed call दें।` : ''} सहायता के लिए customer care ${bank.customerCare} पर call करें।`,
  },
  {
    q: `SMS banking से क्या-क्या services मिलती हैं?`,
    a: `${bank.shortName} SMS banking से मिलने वाली सेवाएं: 1) Account balance check, 2) Mini statement, 3) Transaction alert, 4) Cheque status, 5) ATM card block। Balance check के लिए ${bank.missedCall} पर missed call दें।`,
  },
  {
    q: `SMS banking charges कितने हैं?`,
    a: `Missed call balance check सेवा पूरी तरह मुफ़्त है — कोई charge नहीं लगता। बैंक से आने वाले transaction alert SMS भी फ्री होते हैं। लेकिन अगर आप SMS के बजाय call करते हैं तो आपके telecom operator के call rates लगेंगे।`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "name": `${bank.shortName} SMS Banking — Balance Check`,
      "description": `${bank.name} SMS banking से balance check करने की विधि`,
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Mobile number registered करें", "text": `सुनिश्चित करें कि आपका mobile number ${bank.name} में registered है।` },
        { "@type": "HowToStep", "position": 2, "name": "Missed call दें", "text": `अपने registered mobile से ${bank.missedCall} पर missed call दें।` },
        { "@type": "HowToStep", "position": 3, "name": "SMS प्राप्त करें", "text": `कुछ सेकंड में SMS में आपका account balance आ जाएगा।` },
      ],
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "SMS Banking", "item": `${siteUrl}/sms-banking/` },
        { "@type": "ListItem", "position": 3, "name": bank.shortName, "item": canonicalUrl },
      ],
    },
  ],
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="max-w-3xl mx-auto px-4 py-6">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-1">›</span>
      <a href="/sms-banking/" class="hover:text-brand-600">SMS Banking</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">{bank.shortName}</span>
    </nav>

    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-1">{bank.slug === 'punjab-gramin' ? 'Punjab Gramin Bank Balance Check Number' : `${bank.shortName} SMS Banking`}</h1>
      <p class="text-brand-100 text-sm">{bank.nameHindi} — SMS से balance check और अधिक</p>
    </div>

    <!-- Balance Check CTA -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📱 Balance Check करें</h2>
      <p class="text-gray-600 text-sm mb-4">
        अपने registered mobile number से नीचे दिए गए number पर missed call दें।
        कुछ ही सेकंड में SMS में आपका account balance आ जाएगा।
      </p>
      <a href={`tel:${bank.missedCall}`}
         class="inline-flex items-center gap-2 bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-brand-700 transition-colors">
        <span>📞 {bank.missedCall}</span>
      </a>
      {bank.missedCallAlt && (
        <p class="text-sm text-gray-500 mt-3">
          Mini statement के लिए: <a href={`tel:${bank.missedCallAlt}`} class="text-brand-700 font-medium">{bank.missedCallAlt}</a>
        </p>
      )}
    </div>

    <!-- Steps -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">📝 SMS Banking Registration Steps</h2>
      <ol class="space-y-3 text-sm text-gray-700">
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <span>सुनिश्चित करें कि आपका mobile number {bank.name} में registered है</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <span>अगर नहीं है तो nearest branch या ATM से mobile number register करें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <span>Registered mobile से {bank.missedCall} पर missed call दें</span>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center text-xs font-bold">4</span>
          <span>कुछ सेकंड में SMS में balance जानकारी प्राप्त करें</span>
        </li>
      </ol>
    </div>

    <!-- Services -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📋 SMS Banking सेवाएं</h2>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Account balance check (missed call)</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Mini statement — last 5 transactions</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Transaction alert SMS</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Cheque status enquiry</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> ATM/debit card block</li>
        <li class="flex gap-2"><span class="text-brand-600">✓</span> Account statement request</li>
      </ul>
    </div>

    {bank.notes && (
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
        <p class="text-sm text-blue-800">ℹ️ {bank.notes}</p>
      </div>
    )}

    <!-- FAQ -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">❓ अक्सर पूछे जाने वाले प्रश्न</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="border-b border-gray-100 pb-4 last:border-0">
            <h3 class="font-medium text-gray-900 text-sm mb-2">{faq.q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Related Links -->
    <div class="grid grid-cols-2 gap-3 mb-3">
      <a href={`/bank/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">📞 Missed Call</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Balance Check →</p>
      </a>
      <a href={`/customer-care/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">🎧 Customer Care</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Helpline →</p>
      </a>
    </div>
    <div class="grid grid-cols-2 gap-3 mb-6">
      <a href={`/mini-statement/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">📄 Mini Statement</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} Last 5 Txns →</p>
      </a>
      <a href={`/balance-enquiry/${bank.slug}/`}
         class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:border-brand-300 transition-colors">
        <p class="text-xs text-gray-500 mb-1">💰 Balance Enquiry</p>
        <p class="text-sm font-medium text-brand-700">{bank.shortName} All Methods →</p>
      </a>
    </div>
  </div>
</Layout>
