---
import Layout from '../../layouts/Layout.astro';
import { banks } from '../../data/banks';
import type { Bank } from '../../data/banks';

export function getStaticPaths() {
  return banks.map((bank: Bank) => ({ params: { slug: bank.slug }, props: { bank } }));
}
interface Props { bank: Bank }
const { bank } = Astro.props;
const isMissedCall = bank.balanceMode === 'missed-call';
const siteUrl = 'https://balcheck.in';
const canonicalUrl = `${siteUrl}/sms-banking/${bank.slug}/`;
const title = bank.slug === 'punjab-gramin'
  ? 'Punjab Gramin Bank Balance Check Number — Customer Care / IVR'
  : `${bank.shortName} SMS Banking — Official Registration & Balance Methods`;
const h1Text = bank.slug === 'punjab-gramin' ? 'Punjab Gramin Bank Balance Check Number' : `${bank.shortName} SMS Banking`;
const description = `${bank.name} SMS banking guide. Official commands और registration के लिए bank website देखें। Balance enquiry: ${bank.missedCall} (${isMissedCall ? 'missed call' : 'customer care/IVR'})।`;
const balanceText = isMissedCall
  ? `Registered mobile से verified balance number ${bank.missedCall} पर missed call दें। SMS में balance मिल सकता है।`
  : `${bank.missedCall} Customer Care / IVR number है। इसे missed-call service न समझें; call करके balance enquiry विकल्प चुनें।`;
const faqs = [
  { q: `${bank.shortName} SMS banking कैसे use करें?`, a: `Current SMS commands और registration process के लिए ${bank.website} पर official instructions देखें। Commands bank के अनुसार बदलते हैं।` },
  { q: `${bank.shortName} balance कैसे check करें?`, a: balanceText },
  { q: `SMS नहीं आया तो क्या करें?`, a: `Mobile registration check करें और customer care ${bank.customerCare} से official service availability confirm करें। OTP, PIN या CVV share न करें।` },
];
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'SMS Banking', item: `${siteUrl}/sms-banking/` },
      { '@type': 'ListItem', position: 3, name: bank.shortName, item: canonicalUrl },
    ] },
  ],
};
---
<Layout title={title} description={description} canonical={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <div class="max-w-3xl mx-auto px-4 py-6">
    <nav class="text-sm text-gray-500 mb-4"><a href="/">Home</a><span class="mx-1">›</span><a href="/sms-banking/">SMS Banking</a><span class="mx-1">›</span><span>{bank.shortName}</span></nav>
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl p-6 text-white mb-6">
      <h1 class="text-2xl font-bold mb-1">{h1Text}</h1>
      <p class="text-brand-100 text-sm">Official instructions और सुरक्षित balance enquiry methods</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold mb-3">Balance Enquiry</h2>
      <p class="text-gray-700 text-sm mb-4">{balanceText}</p>
      <a href={`tel:${bank.missedCall}`} class="inline-flex bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium">📞 {bank.missedCall}</a>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="text-lg font-semibold mb-3">Official SMS Banking Setup</h2>
      <ol class="space-y-2 text-sm text-gray-700">
        <li>1. Mobile number bank account में registered रखें</li>
        <li>2. <a href={bank.website} target="_blank" rel="noopener noreferrer" class="text-brand-700 font-medium">{bank.shortName} official website</a> पर current SMS commands देखें</li>
        <li>3. केवल bank द्वारा published command और short code का उपयोग करें</li>
        <li>4. सहायता के लिए <a href={`tel:${bank.customerCare}`} class="text-brand-700 font-medium">{bank.customerCare}</a> पर call करें</li>
      </ol>
      <p class="text-xs text-amber-800 bg-amber-50 border border-amber-200 rounded-lg p-3 mt-4">BalCheck unverified SMS commands publish नहीं करता। Bank commands बदल सकते हैं।</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="text-lg font-semibold mb-4">FAQ</h2>
      <div class="space-y-4">{faqs.map(f => <div><h3 class="font-medium text-sm mb-1">{f.q}</h3><p class="text-gray-600 text-sm">{f.a}</p></div>)}</div>
    </div>
    <div class="grid grid-cols-2 gap-3 mt-6">
      <a href={`/mini-statement/${bank.slug}/`} class="bg-white rounded-xl border border-gray-200 p-4 text-center text-brand-700">Mini Statement →</a>
      <a href={`/balance-enquiry/${bank.slug}/`} class="bg-white rounded-xl border border-gray-200 p-4 text-center text-brand-700">Balance Enquiry →</a>
    </div>
  </div>
</Layout>
