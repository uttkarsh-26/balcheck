---
/**
 * VideoHeroBanner.astro — full-width video background hero with overlay text.
 * Same pattern as kiststatus.in's VideoHeroBanner.
 * Video is muted/autoplay/loop, with a dark scrim so white text is readable.
 */
interface Props {
  src: string;
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  poster?: string;
  headingLevel?: 1 | 2;
}
const { src, title, subtitle, ctaText, ctaHref, poster, headingLevel = 1 } = Astro.props;
const HeadingTag = `h${headingLevel}` as 'h1' | 'h2';

const siteOrigin = Astro.url.origin;
const resolveUrl = (p: string) => (p.startsWith('http') ? p : `${siteOrigin}${p.startsWith('/') ? '' : '/'}${p}`);
const videoUrl = resolveUrl(src);
const posterUrl = poster ? resolveUrl(poster) : undefined;
const thumbnailUrl = posterUrl ?? videoUrl;

function normalizeDate(date: string): string {
  if (!date) return '';
  const ist = '+05:30';
  if (date.includes('T')) {
    if (/Z|[+-]\d{2}:\d{2}$/.test(date)) return date;
    return `${date}${ist}`;
  }
  return `${date}T00:00:00${ist}`;
}
---

<section class="relative w-full overflow-hidden bg-gray-900">
  {/* Video background */}
  <div class="absolute inset-0 w-full h-full">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      src={src}
      poster={posterUrl}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      Your browser does not support the video tag.
    </video>
    {/* Dark gradient scrim for text readability */}
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/50 to-gray-900/30"></div>
  </div>

  {/* Foreground content */}
  <div class="relative z-10 max-w-4xl mx-auto px-4 py-16 md:py-24 text-center text-white">
    <HeadingTag class="text-2xl sm:text-4xl md:text-5xl font-bold leading-tight mb-4 drop-shadow-lg">
      {title}
    </HeadingTag>
    {subtitle && (
      <p class="mt-3 text-base sm:text-lg text-gray-200 max-w-2xl mx-auto drop-shadow-md">
        {subtitle}
      </p>
    )}
    {ctaText && ctaHref && (
      <a
        href={ctaHref}
        class="inline-block mt-6 px-8 py-3 text-base font-semibold rounded-full bg-gradient-to-br from-brand-600 to-brand-700 text-white shadow-lg transition-transform hover:-translate-y-0.5"
      >
        {ctaText}
      </a>
    )}
  </div>

  {/* VideoObject schema for SEO */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: title,
    description: subtitle ?? title,
    thumbnailUrl,
    contentUrl: videoUrl,
    embedUrl: videoUrl,
    uploadDate: normalizeDate(new Date().toISOString().slice(0, 10)),
    duration: 'PT6S',
    inLanguage: 'hi',
    isAccessibleForFree: true,
    publisher: {
      '@type': 'Organization',
      name: 'BalCheck.in',
      logo: { '@type': 'ImageObject', url: `${siteOrigin}/favicon.svg` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url.toString() },
  })} />
</section>
