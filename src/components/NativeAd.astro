---
// Monetag Native Banner ad slot
// Replace NATIVE_ZONE_ID with the zone ID from your Monetag dashboard.
// Container has min-height to prevent CLS when the ad loads asynchronously.
---

<div class="native-ad-container w-full my-6 min-h-[250px] md:min-h-[100px] flex items-center justify-center bg-gray-100 rounded-lg border border-gray-200 overflow-hidden">
  <script is:inline>
    (function(s){
      s.dataset.zone = 'NATIVE_ZONE_ID';
      s.src = 'https://n6wxm.com/native.min.js';
    })(document.currentScript.parentNode.appendChild(document.createElement('script')));
  </script>
</div>
